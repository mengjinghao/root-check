```gitignore
# Build artifacts
build/
dist/
*.o
*.obj
*.so
*.a

# Dependencies
node_modules/
venv/
.venv/
__pycache__/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS specific
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Gradle
.gradle/
target/

# MyPy
.mypy_cache/

# Pytest
.pytest_cache/
```